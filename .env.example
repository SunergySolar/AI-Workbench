# Set to true to write DEBUG-level logs to the log file (default: INFO and above only).
DEBUG_LOGGING=false

# Comma-separated path prefixes to include. Only sessions whose working
# directory starts with one of these will be counted. Leave blank to include all.
# Example: C:\Users\Amber Price\OneDrive\Documents\Zoe
INCLUDE_PATHS=

# Days of the week to exclude from limit calculations (0=Monday, 6=Sunday).
# These days are still displayed in totals but ignored when computing averages.
EXCLUDE_WEEKDAYS=5,6

# ── Console stats (requires: pip install selenium) ────────────────────────────
# Set to true to enable scraping console.anthropic.com for account-level usage.
# When false (default), the Console section is hidden from the widget entirely.
CONSOLE_FETCHER_ENABLED=false

# How often to re-scrape console.anthropic.com for account-level usage (minutes).
CONSOLE_REFRESH_MINUTES=30

# Set to false to always show the Chrome window (useful for debugging scrape issues).
CONSOLE_HEADLESS=true

# Alternative Chrome path as a last resort (used in CHROME_PATHS list).
# Leave empty to use the default paths.
# Example: C:\Program Files\Google\Chrome Stable\Application\chrome.exe
CHROME_PATHS_VAR=

# ── Local LLM server ──────────────────────────────────────────────────────────
# Maximum number of lines kept in the LLM Backend server log (oldest removed first).
LLM_LOG_MAX_LINES=200

# Base URL for the local LLM (used by Claude Code's ANTHROPIC_BASE_URL override).
# Change this if your server runs on a different machine or port.
LLM_URL=http://localhost:8001
LLM_API_KEY=sk-your-key-here
LLM_MODEL=your-model-alias

# Full command to launch llama-server. Change path and flags as required.
LLAMA_SERVER_CMD=

# Port for Chrome remote debugging (used by CDP account stats).
BROWSER_DEBUG_PORT=9222

# Keep the local LLM server alive when switching away from it (true/false).
KEEP_LLM_ACTIVE=true

# ── PORT REGISTRY — update here first, then nowhere else ─────────────────────
# Next free port: 8008
#
# Host port         Internal  Service             Compose file
# ──────────────────────────────────────────────────────────────────────────────
PORT_LITELLM=4001           # 4000     litellm             litellm.yml
PORT_POSTGRES=5432          # 5432     litellm_db          litellm.yml
PORT_PROMETHEUS=9090        # 9090     prometheus          litellm.yml
PORT_VLLM_QWEN=8002         # 8000     vllm-qwen           vllm.yml
PORT_VLLM_QWEN_VL=8006      # 8000     vllm-qwen-vl        vllm.yml
PORT_KOKORO_API=8004        # 8000     kokoro-api          kokoro.yml
PORT_CLASSIFIER=8005        # 8000     classifier          classifier.yml
PORT_OPENWEBUI=8007         # 8080     openwebui           openwebui.yml
PORT_UNSLOTH_MODEL=8000     # 8000     unsloth (model)     unsloth.yml
PORT_UNSLOTH_JUPYTER=8888   # 8888     unsloth (jupyter)   unsloth.yml
PORT_UNSLOTH_SSH=2222       # 22       unsloth (ssh)       unsloth.yml

# ── vLLM config ──────────────────────────────────────────────────────────────
# HuggingFace token — shared by both vLLM (gated/registered model downloads)
# and Open WebUI (gated embedding / RAG model downloads).
# Get one at https://huggingface.co/settings/tokens
# (Model, port, and other settings are defined in docker-compose.vllm.yml)
HF_TOKEN=hf_fake_token_here

# ── LiteLLM config ──────────────────────────────────────────────────────────────
DEFAULT_LITELLM_MASTER_KEY=sk-your-master-key
DEFAULT_LITELLM_MODEL_NAME=qwen3.6
DEFAULT_LITELLM_MODEL=openai/your-model
DEFAULT_LITELLM_MODEL_API_KEY=sk-your-api-key
DEFAULT_LITELLM_MODEL_API_BASE=http://localhost:8000/v1
DEFAULT_LITELLM_DATABASE_URL=postgresql://user:password@localhost:5432/litellm
DEFAULT_LITELLM_MCP_PHOENIX_URL=https://phoenix-mcp.com/mcp
DEFAULT_LITELLM_MCP_PHOENIX_AUTH_VALUE=your-phoenix-auth-value

# ── Open WebUI config ─────────────────────────────────────────────────────────
# Persistent session secret. Without a stable value, every container recreate
# logs out all users. Rotate with: openssl rand -hex 32
OPENWEBUI_SECRET_KEY=change-me-run-openssl-rand-hex-32

# Allowed CORS origin for API calls into Open WebUI. Must match the origin
# users actually load the UI from (scheme + host + port, no trailing slash).
# Comma-separate multiple values. Use "*" only for local-only / dev use.
CORS_ALLOW_ORIGIN=https://chat.zeoenergy.com

# OpenAI-compatible endpoint Open WebUI calls for chat completions. In this
# stack it is the LiteLLM proxy on the ai_shared Docker network — must be the
# service DNS name (litellm:4000), NOT localhost, when running in compose.
OPENWEBUI_OPENAI_API_BASE_URL=http://litellm:4000/v1

# API key Open WebUI sends to the endpoint above. Use a LiteLLM virtual key
# scoped to the specific chat models Open WebUI should see (create one in the
# LiteLLM Admin UI → Virtual Keys, or via the /key/generate API). Avoid using
# DEFAULT_LITELLM_MASTER_KEY here — that key sees every model including TTS
# (kokoro) and would expose unrelated entries in the chat model picker.
OPENWEBUI_OPENAI_API_KEY=

# Disable Ollama discovery probe — every model in this stack is served via
# LiteLLM. Flip to "true" only if you also stand up an Ollama container.
OPENWEBUI_ENABLE_OLLAMA_API=false

# Allow new account sign-ups. "false" locks the deployment after the first
# user; "true" lets anyone with the URL create an account.
OPENWEBUI_ENABLE_SIGNUP=true

# Role assigned to new signups. "pending" routes them to an admin approval
# queue (Admin Panel → Users) before they can chat. Other values: "user",
# "admin". Note: the very first account ever created always becomes admin
# regardless of this setting.
OPENWEBUI_DEFAULT_USER_ROLE=pending

# Public base URL Open WebUI is reachable at. Used to build OAuth callback
# URLs. Set to the address users actually type into the browser — e.g.
# http://localhost:8007 for local-only use, or https://chat.example.com
# behind a reverse proxy.
OPENWEBUI_WEBUI_URL=http://chat.zeoenergy.com:8007

# ── Open WebUI: Google OAuth ─────────────────────────────────────────────────
# Master switch for OAuth sign-up flows.
OPENWEBUI_ENABLE_OAUTH_SIGNUP=true

# When true, an OAuth login matching an existing local account's email is
# merged into that local account instead of creating a duplicate.
OPENWEBUI_OAUTH_MERGE_ACCOUNTS_BY_EMAIL=true

# Google Cloud OAuth 2.0 client credentials.
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: ${OPENWEBUI_WEBUI_URL}/oauth/google/callback
OPENWEBUI_GOOGLE_CLIENT_ID=
OPENWEBUI_GOOGLE_CLIENT_SECRET=

# OIDC discovery document for the OAuth provider. Required for logout to
# properly terminate the provider-side session — without it Open WebUI logs
# a warning and the logout flow only clears the local cookie.
# For Google: https://accounts.google.com/.well-known/openid-configuration
OPENWEBUI_OPENID_PROVIDER_URL=https://accounts.google.com/.well-known/openid-configuration

# User-Agent string Open WebUI uses for outbound HTTP requests from its RAG /
# web loaders (langchain_community). Identifies your deployment to remote
# sites; silences the "USER_AGENT environment variable not set" warning.
OPENWEBUI_USER_AGENT=OpenWebUI/1.0 (+https://github.com/open-webui/open-webui)

# Seconds Open WebUI waits for an MCP server to respond to the initialize
# handshake before giving up. Raise this if Phoenix or another remote MCP
# server cold-starts slowly (default upstream: 10).
OPENWEBUI_MCP_INITIALIZE_TIMEOUT=30

# ── Cloudflare Tunnel ────────────────────────────────────────────────────────
# Token from a Cloudflare Zero Trust tunnel that maps a public hostname (e.g.
# chat.zeoenergy.com) to a local origin service (e.g. http://localhost:8007).
# Create at: https://one.dash.cloudflare.com → Networks → Tunnels → Create.
# Consumed by `make tunnel` (see Makefile).
CLOUDFLARE_TUNNEL_TOKEN=

# ── Kokoro TTS config ─────────────────────────────────────────────────────────
# URL of the kokoro-app inference container. In Docker Compose this resolves via
# the service name. For local development point it at localhost.
KOKORO_APP_URL=http://kokoro-app:8085

# Base URL returned by the text_to_speech MCP tool. Used to build the audio
# playback link. Override if the server runs on a different host or port.
AUDIO_BASE_URL=http://localhost:8004 # port must match PORT_KOKORO_API