# Set to true to write DEBUG-level logs to the log file (default: INFO and above only).
DEBUG_LOGGING=false

# Comma-separated path prefixes to include. Only sessions whose working
# directory starts with one of these will be counted. Leave blank to include all.
# Example: C:\Users\Amber Price\OneDrive\Documents\Zoe
INCLUDE_PATHS=

# Days of the week to exclude from limit calculations (0=Monday, 6=Sunday).
# These days are still displayed in totals but ignored when computing averages.
EXCLUDE_WEEKDAYS=5,6

# ── Console stats (requires: pip install selenium) ────────────────────────────
# Set to true to enable scraping console.anthropic.com for account-level usage.
# When false (default), the Console section is hidden from the widget entirely.
CONSOLE_FETCHER_ENABLED=false

# How often to re-scrape console.anthropic.com for account-level usage (minutes).
CONSOLE_REFRESH_MINUTES=30

# Set to false to always show the Chrome window (useful for debugging scrape issues).
CONSOLE_HEADLESS=true

# Alternative Chrome path as a last resort (used in CHROME_PATHS list).
# Leave empty to use the default paths.
# Example: C:\Program Files\Google\Chrome Stable\Application\chrome.exe
CHROME_PATHS_VAR=

# ── Local LLM server ──────────────────────────────────────────────────────────
# Maximum number of lines kept in the LLM Backend server log (oldest removed first).
LLM_LOG_MAX_LINES=200

# Base URL for the local LLM (used by Claude Code's ANTHROPIC_BASE_URL override).
# Change this if your server runs on a different machine or port.
LLM_URL=http://localhost:8001
LLM_API_KEY=sk-your-key-here
LLM_MODEL=your-model-alias

# Full command to launch llama-server. Change path and flags as required.
LLAMA_SERVER_CMD=

# Port for Chrome remote debugging (used by CDP account stats).
BROWSER_DEBUG_PORT=9222

# Keep the local LLM server alive when switching away from it (true/false).
KEEP_LLM_ACTIVE=true

# ── vLLM config ──────────────────────────────────────────────────────────────
# HuggingFace token required for downloading gated/registered models.
# Get one at https://huggingface.co/settings/tokens
# (Model, port, and other settings are defined in docker-compose.vllm.yml)
HF_TOKEN=hf_fake_token_here

# ── LiteLLM config ──────────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=sk-your-master-key
LITELLM_SALT_KEY=sk-your-salt-key
LITELLM_MODEL_NAME=qwen3.6
LITELLM_MODEL=openai/your-model
LITELLM_API_KEY=sk-your-api-key
LITELLM_API_BASE=http://localhost:8000/v1
LITELLM_DATABASE_URL=postgresql://user:password@localhost:5432/litellm

# ── Kokoro TTS config ─────────────────────────────────────────────────────────
# URL of the kokoro-app inference container. In Docker Compose this resolves via
# the service name. For local development point it at localhost.
KOKORO_APP_URL=http://kokoro-app:8085